@model SmsProviderSearchModel

@{
    Layout = "_AdminLayout";
    NopHtml.SetActiveMenuItemSystemName("SmsActions.SmsProviders");

    ViewBag.PageTitle = T("Admin.NopStation.Core.SmsProviders").Text;
}

<div class="content-header clearfix">
    <h1 class="float-left">
        @T("Admin.NopStation.Core.SmsProviders")
    </h1>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default">
                    <div class="card-body">
                        @await Html.PartialAsync("Table", new DataTablesModel
                        {
                            Name = "sms-providers-grid",
                            UrlRead = new DataUrl("Providers", "Sms", null),
                            UrlUpdate = new DataUrl("ProviderUpdate", "Sms", null),
                            Length = Model.PageSize,
                            LengthMenu = Model.AvailablePageSizes,
                            ColumnCollection = new List<ColumnProperty>
                            {
                                new ColumnProperty(nameof(SmsProviderModel.FriendlyName))
                                {
                                    Title = T("Admin.NopStation.Core.SmsProviders.Fields.FriendlyName").Text,
                                    Width = "250"
                                },
                                new ColumnProperty(nameof(SmsProviderModel.SystemName))
                                {
                                    Title = T("Admin.NopStation.Core.SmsProviders.Fields.SystemName").Text,
                                    Width = "250"
                                },
                                new ColumnProperty(nameof(SmsProviderModel.DisplayOrder))
                                {
                                    Title = T("Admin.NopStation.Core.SmsProviders.Fields.DisplayOrder").Text,
                                    Width = "100",
                                    ClassName = NopColumnClassDefaults.CenterAll,
                                    Editable = true,
                                    EditType = EditType.Number
                                },
                                new ColumnProperty(nameof(SmsProviderModel.IsActive))
                                {
                                    Title = T("Admin.NopStation.Core.SmsProviders.Fields.IsActive").Text,
                                    Width = "100",
                                    ClassName = NopColumnClassDefaults.CenterAll,
                                    Render = new RenderBoolean()
                                },
                                new ColumnProperty(nameof(SmsProviderModel.SystemName))
                                {
                                    Title = T("Admin.NopStation.Core.SmsProviders.Configure").Text,
                                    Width = "150",
                                    ClassName = NopColumnClassDefaults.Button,
                                    Render = new RenderCustom("renderSmsProviderConfigure")
                                },
                                new ColumnProperty(nameof(SmsProviderModel.SystemName))
                                {
                                    Title = T("Admin.Common.Edit").Text,
                                    Width = "200",
                                    ClassName = NopColumnClassDefaults.Button,
                                    Render = new RenderButtonsInlineEdit()
                                }
                            }
                        })

                        <script>
                            function renderSmsProviderConfigure(data, type, row, meta) {
                                if (row.ConfigurationUrl && row.ConfigurationUrl.length > 0) {
                                    return '<a class="btn btn-default" href="' + row.ConfigurationUrl + '"><i class="fas fa-gear"></i>@T("Admin.NopStation.Core.SmsProviders.Configure").Text</a>';
                                } else {
                                    return '';
                                }
                            }
                        </script>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
